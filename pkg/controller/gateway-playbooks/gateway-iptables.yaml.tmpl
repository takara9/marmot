---
- name: Configure marmot gateway iptables
  hosts: all
  become: true
  gather_facts: false
  tasks:
    - name: Ensure IPv4 forwarding is enabled
      ansible.builtin.lineinfile:
        path: /etc/sysctl.conf
        regexp: '^net.ipv4.ip_forward='
        line: net.ipv4.ip_forward=1
        create: true

    - name: Apply sysctl configuration
      ansible.builtin.command: sysctl -p

    - name: Ensure gateway dedicated filter chains exist
      ansible.builtin.shell: |
        set -euo pipefail
        iptables -N MARMOT-GW-INPUT 2>/dev/null || true
        iptables -N MARMOT-GW-FORWARD 2>/dev/null || true
      args:
        executable: /bin/bash

    - name: Ensure gateway dedicated nat chain exists
      ansible.builtin.shell: |
        set -euo pipefail
        iptables -t nat -N MARMOT-GW-PREROUTING 2>/dev/null || true
      args:
        executable: /bin/bash

    - name: Flush gateway dedicated filter chains
      ansible.builtin.command: iptables -F {{ item }}
      loop:
        - MARMOT-GW-INPUT
        - MARMOT-GW-FORWARD

    - name: Flush gateway dedicated nat chain
      ansible.builtin.command: iptables -t nat -F MARMOT-GW-PREROUTING

    - name: Rebind INPUT jump to gateway dedicated chain at top
      ansible.builtin.shell: |
        set -euo pipefail
        while iptables -C INPUT -j MARMOT-GW-INPUT 2>/dev/null; do
          iptables -D INPUT -j MARMOT-GW-INPUT
        done
        iptables -I INPUT 1 -j MARMOT-GW-INPUT
      args:
        executable: /bin/bash

    - name: Rebind FORWARD jump to gateway dedicated chain at top
      ansible.builtin.shell: |
        set -euo pipefail
        while iptables -C FORWARD -j MARMOT-GW-FORWARD 2>/dev/null; do
          iptables -D FORWARD -j MARMOT-GW-FORWARD
        done
        iptables -I FORWARD 1 -j MARMOT-GW-FORWARD
      args:
        executable: /bin/bash

    - name: Rebind PREROUTING jump to gateway dedicated nat chain at top
      ansible.builtin.shell: |
        set -euo pipefail
        while iptables -t nat -C PREROUTING -j MARMOT-GW-PREROUTING 2>/dev/null; do
          iptables -t nat -D PREROUTING -j MARMOT-GW-PREROUTING
        done
        iptables -t nat -I PREROUTING 1 -j MARMOT-GW-PREROUTING
      args:
        executable: /bin/bash

    - name: Allow established input traffic
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-INPUT
        ctstate:
          - ESTABLISHED
          - RELATED
        jump: ACCEPT
        comment: marmot-gateway

    - name: Allow established forwarded traffic
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-FORWARD
        ctstate:
          - ESTABLISHED
          - RELATED
        jump: ACCEPT
        comment: marmot-gateway

    - name: Allow loopback input traffic
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-INPUT
        in_interface: lo
        jump: ACCEPT
        comment: marmot-gateway

{{- range .RemoteCIDRs }}
    - name: Allow all input traffic from {{ . }}
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-INPUT
        source: {{ . }}
        jump: ACCEPT
        comment: marmot-gateway
{{- end }}

    - name: Drop all input traffic from non-remoteCIDR
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-INPUT
        jump: DROP
        comment: marmot-gateway

{{- range .RemoteCIDRs }}
    - name: Allow all forwarded traffic from {{ . }}
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-FORWARD
        source: {{ . }}
        jump: ACCEPT
        comment: marmot-gateway
{{- end }}

    - name: Drop all forwarded traffic from non-remoteCIDR
      ansible.builtin.iptables:
        table: filter
        chain: MARMOT-GW-FORWARD
        jump: DROP
        comment: marmot-gateway

{{- range .Ports }}
{{- $port := .Port }}
{{- $protocol := .Protocol }}
{{- range $.RemoteCIDRs }}
    - name: Ensure DNAT rule for {{ $protocol }}/{{ $port }} from {{ . }}
      ansible.builtin.iptables:
        table: nat
        chain: MARMOT-GW-PREROUTING
        source: {{ . }}
        protocol: {{ $protocol }}
        destination_port: {{ $port }}
        jump: DNAT
        to_destination: {{ $.TargetIP }}:{{ $port }}
        comment: marmot-gateway
{{- end }}
{{- end }}
    - name: Ensure masquerade rule
      ansible.builtin.iptables:
        table: nat
        chain: POSTROUTING
        jump: MASQUERADE
        comment: marmot-gateway