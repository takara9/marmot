---
- name: Configure marmot gateway iptables
  hosts: all
  become: true
  gather_facts: false
  tasks:
    - name: Ensure IPv4 forwarding is enabled
      ansible.builtin.lineinfile:
        path: /etc/sysctl.conf
        regexp: '^net.ipv4.ip_forward='
        line: net.ipv4.ip_forward=1
        create: true

    - name: Apply sysctl configuration
      ansible.builtin.command: sysctl -p

    - name: Allow established input traffic
      ansible.builtin.iptables:
        table: filter
        chain: INPUT
        ctstate:
          - ESTABLISHED
          - RELATED
        jump: ACCEPT
        comment: marmot-gateway

    - name: Allow established forwarded traffic
      ansible.builtin.iptables:
        table: filter
        chain: FORWARD
        ctstate:
          - ESTABLISHED
          - RELATED
        jump: ACCEPT
        comment: marmot-gateway

    - name: Allow loopback input traffic
      ansible.builtin.iptables:
        table: filter
        chain: INPUT
        in_interface: lo
        jump: ACCEPT
        comment: marmot-gateway

    - name: Allow all input traffic from remoteCIDR
      ansible.builtin.iptables:
        table: filter
        chain: INPUT
        source: {{ $.RemoteCIDR }}
        jump: ACCEPT
        comment: marmot-gateway

    - name: Drop all input traffic from non-remoteCIDR
      ansible.builtin.iptables:
        table: filter
        chain: INPUT
        jump: DROP
        comment: marmot-gateway

    - name: Allow all forwarded traffic from remoteCIDR
      ansible.builtin.iptables:
        table: filter
        chain: FORWARD
        source: {{ $.RemoteCIDR }}
        jump: ACCEPT
        comment: marmot-gateway

    - name: Drop all forwarded traffic from non-remoteCIDR
      ansible.builtin.iptables:
        table: filter
        chain: FORWARD
        jump: DROP
        comment: marmot-gateway

{{- range .Ports }}
    - name: Ensure DNAT rule for {{ .Protocol }}/{{ .Port }}
      ansible.builtin.iptables:
        table: nat
        chain: PREROUTING
        source: {{ $.RemoteCIDR }}
        protocol: {{ .Protocol }}
        destination_port: {{ .Port }}
        jump: DNAT
        to_destination: {{ $.TargetIP }}:{{ .Port }}
        comment: marmot-gateway

{{- end }}
    - name: Ensure masquerade rule
      ansible.builtin.iptables:
        table: nat
        chain: POSTROUTING
        jump: MASQUERADE
        comment: marmot-gateway