---
- name: Configure marmot gateway iptables
  hosts: all
  become: true
  gather_facts: false
  tasks:
    - name: Ensure IPv4 forwarding is enabled
      ansible.builtin.lineinfile:
        path: /etc/sysctl.conf
        regexp: '^net.ipv4.ip_forward='
        line: net.ipv4.ip_forward=1
        create: true

    - name: Apply sysctl configuration
      ansible.builtin.command: sysctl -p

{{- range .Ports }}
    - name: Ensure DNAT rule for {{ .Protocol }}/{{ .Port }}
      ansible.builtin.iptables:
        table: nat
        chain: PREROUTING
        protocol: {{ .Protocol }}
        destination_port: {{ .Port }}
        jump: DNAT
        to_destination: {{ $.TargetIP }}:{{ .Port }}
        comment: marmot-gateway

{{- end }}
    - name: Ensure masquerade rule
      ansible.builtin.iptables:
        table: nat
        chain: POSTROUTING
        jump: MASQUERADE
        comment: marmot-gateway